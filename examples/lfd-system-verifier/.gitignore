# =============================================================================
# .gitignore — examples/lfd-system-verifier (project-local)
# =============================================================================
# The verifier-project is part of the LFD bundle, but it generates
# its own per-cycle artifacts at runtime that should never be
# committed. The "what was tested" outputs (verification-report.*,
# logs/iteration-log.md, logs/best-cycle.json, logs/held-out.log)
# ARE committed by intent — they're the verifier's deliverable.
# See README.md for the file layout and what each file means.
# =============================================================================

# Per-cycle loop artifacts (regenerated by run-verification.sh;
# see README.md for the per-cycle lifecycle)
.iterations/
logs/cycle-*/
logs/design-set-score.snapshot.json
logs/sub-losses.snapshot.json
logs/.loop_start_ts
logs/tokens_used.txt
logs/tokens_last_cycle.txt

# Per-task scratch logs (regenerated every run; the *aggregate*
# held-out.log is committed because it's the "what was tested" record)
logs/d*-*.log
logs/d*.log
logs/h1-shared-parser-shape.log
logs/h2-install-determinism.log
logs/h3-drift-opt-in.log
logs/h4-force-entropy-trigger.log
logs/h5-compatibility-matrix-consistency.log
logs/method-*.log

# The loop-driver symlink is created at runtime by
# run-verification.sh. It points at the canonical loop-driver
# in the parent repo's skills/ directory, so committing it
# would create a circular reference.
loop-driver

# The copied sub-loss scorer (regenerated by run-verification.sh
# from the canonical cline-orchestration/references/compute-sub-losses.py)
verifiers/compute_sub_losses.py
